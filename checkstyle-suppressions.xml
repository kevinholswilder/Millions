<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
        "https://checkstyle.org/dtds/suppressions_1_0.dtd">

<!-- example: https://maven.apache.org/plugins/maven-checkstyle-plugin/examples/suppressions-filter.html -->

<suppressions>
    <!-- suppress abbreviation warnings: CSVreader will not trigger mvn checkstyle -->
    <suppress checks="AbbreviationAsWordInName"
              files=".java"/>
</suppressions>
